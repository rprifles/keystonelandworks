---
import { SITE, SERVICES } from '../consts.js';
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="brand">
        <span class="brand-mark">K</span>
        <span class="brand-text">
          <span class="brand-name">Keystone LandWorks</span>
          <span class="brand-tagline">Forestry Mulching · Land Clearing · Excavation</span>
        </span>
      </a>

      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <nav class="primary-nav" aria-label="Primary">
        <ul>
          <li><a href="/">Home</a></li>
          <li class="has-dropdown">
            <a href="/services">Services</a>
            <ul class="dropdown">
              {SERVICES.map(s => (
                <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
              ))}
            </ul>
          </li>
          <li><a href="/service-areas">Service Areas</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <a href={`tel:${SITE.phoneRaw}`} class="header-phone btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="phone-link">{SITE.phone}</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: white;
    border-bottom: 1px solid var(--color-line);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    gap: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--color-ink);
  }

  .brand:hover {
    color: var(--color-ink);
  }

  .brand-mark {
    width: 44px;
    height: 44px;
    background: var(--color-primary);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.15rem;
    color: var(--color-primary-dark);
  }

  .brand-tagline {
    font-size: 0.72rem;
    color: var(--color-mute);
    letter-spacing: 0.04em;
    margin-top: 0.15rem;
  }

  .primary-nav {
    display: none;
  }

  @media (min-width: 1100px) {
    .primary-nav {
      display: block;
    }

    .primary-nav ul {
      display: flex;
      list-style: none;
      gap: 1.75rem;
      align-items: center;
    }

    .primary-nav a {
      font-weight: 500;
      color: var(--color-ink);
      padding: 0.5rem 0;
      position: relative;
    }

    .primary-nav a:hover {
      color: var(--color-primary);
    }

    .has-dropdown {
      position: relative;
    }

    .dropdown {
      position: absolute;
      top: 100%;
      left: -1rem;
      background: white;
      border: 1px solid var(--color-line);
      border-radius: 4px;
      box-shadow: var(--shadow-md);
      padding: 0.5rem 0;
      min-width: 240px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(8px);
      transition: all 0.2s;
      display: block !important;
    }

    .has-dropdown:hover .dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown li {
      display: block;
    }

    .dropdown a {
      display: block;
      padding: 0.6rem 1.25rem;
      font-size: 0.95rem;
    }

    .dropdown a:hover {
      background: var(--color-bg-alt);
    }
  }

  .header-phone {
    padding: 0.7rem 1.15rem;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    height: 3px;
    background: var(--color-primary-dark);
    border-radius: 2px;
  }

  @media (min-width: 1100px) {
    .nav-toggle {
      display: none;
    }
  }

  /* Mobile menu open state */
  .primary-nav.open {
    display: block;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border-bottom: 1px solid var(--color-line);
    padding: 1rem 1.5rem 1.5rem;
    box-shadow: var(--shadow-md);
  }

  .primary-nav.open ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .primary-nav.open li {
    border-bottom: 1px solid var(--color-line);
  }

  .primary-nav.open a {
    display: block;
    padding: 0.85rem 0;
    color: var(--color-ink);
    font-weight: 500;
  }

  .primary-nav.open .dropdown {
    padding-left: 1rem;
    list-style: none;
  }

  .primary-nav.open .dropdown a {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
  }

  @media (max-width: 540px) {
    .brand-tagline { display: none; }
    .header-phone .phone-link { display: none; }
    .header-phone { padding: 0.6rem 0.85rem; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.querySelector('.primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
</script>
