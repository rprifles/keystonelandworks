---
import { SITE } from '../consts.js';
const { title = 'Ready to improve your property?', subtitle = `Call ${SITE.phone} or request a free on-site estimate. We serve the entire Northern Neck of Virginia.` } = Astro.props;
---

<section class="cta-banner">
  <div class="container">
    <h2>{title}</h2>
    <p>{subtitle}</p>
    <div class="cta-row">
      <a href={`tel:${SITE.phoneRaw}`} class="btn btn-primary btn-large">
        Call {SITE.phone}
      </a>
      <a href="/contact" class="btn btn-secondary btn-large" style="color: white; border-color: rgba(255,255,255,0.5);">
        Request Free Estimate
      </a>
    </div>
  </div>
</section>

<style>
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .cta-banner :global(.btn-secondary:hover) {
    background: white !important;
    color: var(--color-primary) !important;
    border-color: white !important;
  }
</style>
