---
import { SITE, SERVICES, SERVICE_AREAS } from '../consts.js';
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h3>Keystone LandWorks LLC</h3>
        <p class="footer-tagline">
          Forestry mulching, land clearing, excavation, and gravel driveway installation
          across the Northern Neck of Virginia. {SITE.yearsInBusiness} years in business.
          Licensed and insured.
        </p>
        <p class="footer-nap">
          <strong>{SITE.legalName}</strong><br/>
          {SITE.region}<br/>
          <a href={`tel:${SITE.phoneRaw}`} class="phone-link">{SITE.phone}</a><br/>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
        <a href="/contact" class="btn btn-primary">Get a Free Estimate</a>
      </div>

      <div>
        <h4>Services</h4>
        <ul class="footer-list">
          {SERVICES.map(s => (
            <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4>Service Areas</h4>
        <ul class="footer-list">
          {SERVICE_AREAS.map(a => (
            <li><a href={`/service-areas/${a.slug}/`}>{a.city}, {a.state}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4>Company</h4>
        <ul class="footer-list">
          <li><a href="/about">About Keystone LandWorks</a></li>
          <li><a href="/gallery">Project Gallery</a></li>
          <li><a href="/service-areas">All Service Areas</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact / Estimate</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} {SITE.legalName}. All Rights Reserved.</p>
      <p class="footer-meta">
        Serving the Northern Neck of Virginia — Essex, Richmond, Lancaster, Northumberland, and Westmoreland Counties.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-dark);
    color: var(--color-bg);
    padding: 4rem 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 700px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .site-footer h3,
  .site-footer h4 {
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .site-footer h4 {
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-tagline {
    color: rgba(250, 248, 243, 0.78);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .footer-nap {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .footer-nap a {
    color: var(--color-bg);
  }

  .footer-nap a:hover {
    color: var(--color-accent);
  }

  .footer-list {
    list-style: none;
  }

  .footer-list li {
    margin-bottom: 0.5rem;
  }

  .footer-list a {
    color: rgba(250, 248, 243, 0.75);
    font-size: 0.95rem;
  }

  .footer-list a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(192, 140, 46, 0.2);
    text-align: center;
    color: rgba(250, 248, 243, 0.55);
    font-size: 0.85rem;
  }

  .footer-meta {
    margin-top: 0.5rem;
  }
</style>
