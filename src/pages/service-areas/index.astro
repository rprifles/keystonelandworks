---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { SITE, SERVICE_AREAS } from '../../consts.js';

const title = 'Service Areas in the Northern Neck of Virginia';
const description = 'Keystone LandWorks provides forestry mulching, land clearing, excavation, and gravel driveway services across the entire Northern Neck of Virginia — Tappahannock, Warsaw, Kilmarnock, Montross, Heathsville, Irvington, and more.';
---

<BaseLayout title={title} description={description}>
  <section>
    <div class="container container-narrow" style="text-align: center;">
      <p class="eyebrow">Where We Work</p>
      <h1>Service Areas Across the Northern Neck of Virginia</h1>
      <p style="font-size: 1.15rem; margin-top: 1rem;">
        Keystone LandWorks serves the entire Northern Neck region — Essex, Richmond,
        Lancaster, Northumberland, and Westmoreland Counties. If your property is in or near
        any of the towns below, we cover it.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="grid grid-3">
        {SERVICE_AREAS.map(a => (
          <a href={`/service-areas/${a.slug}/`} class="card service-card">
            <h2 style="font-size: 1.3rem;">{a.city}, {a.state}</h2>
            <p style="color: var(--color-mute); font-size: 0.9rem; margin-bottom: 0.5rem;">{a.county}</p>
            <p>{a.blurb}</p>
            <span class="card-link">Services in {a.city} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
  .service-card { display: block; text-decoration: none; color: inherit; }
  .card-link { display: inline-block; margin-top: 1rem; color: var(--color-accent-dark); font-weight: 600; }
</style>
