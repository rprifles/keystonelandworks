---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { SITE, SERVICES, SERVICE_AREAS } from '../../consts.js';

export function getStaticPaths() {
  return SERVICE_AREAS.map(area => ({
    params: { slug: area.slug },
    props: { area }
  }));
}

const { area } = Astro.props;

const title = `Land Clearing, Forestry Mulching & Excavation in ${area.city}, ${area.state}`;
const metaTitle = `Land Clearing & Forestry Mulching in ${area.city}, ${area.state} | Keystone LandWorks`;
const description = `Forestry mulching, land clearing, excavation, and gravel driveway installation in ${area.city}, ${area.state} (${area.county}). Locally based with 25 years of experience. Free estimates — call ${SITE.phone}.`;

// Local-specific schema
const localSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Land Services in ${area.city}, ${area.state}`,
  "description": description,
  "provider": {
    "@type": "ProfessionalService",
    "name": SITE.legalName,
    "telephone": SITE.phone,
  },
  "areaServed": {
    "@type": "City",
    "name": `${area.city}, ${area.state}`,
    "containedInPlace": {
      "@type": "AdministrativeArea",
      "name": area.county
    }
  }
};
---

<BaseLayout title={metaTitle} description={description} schema={localSchema}>
  <section>
    <div class="container container-narrow">
      <p class="eyebrow">{area.county} · Northern Neck</p>
      <h1>Land Clearing, Forestry Mulching &amp; Excavation in {area.city}, {area.state}</h1>
      <p style="font-size: 1.15rem; margin-top: 1.5rem; color: var(--color-ink-soft);">
        Keystone LandWorks is a locally based land services contractor serving {area.city} and the
        surrounding {area.county} area. We handle forestry mulching, land clearing, excavation,
        and gravel driveway installation for property owners across the entire Northern Neck of Virginia.
      </p>
      <div style="margin-top: 2rem;">
        <a href={`tel:${SITE.phoneRaw}`} class="btn btn-primary btn-large">Call {SITE.phone}</a>
        <a href="/contact" class="btn btn-secondary btn-large" style="margin-left: 0.5rem;">Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div style="max-width: 800px; margin: 0 auto;">
        <h2>Land Services for {area.city}, {area.state} Property Owners</h2>
        <p>{area.blurb}</p>
        <p>
          Whether you have an overgrown lot that needs forestry mulching, a homesite that
          needs clearing for new construction, a gravel driveway that needs to be installed or
          rebuilt, or general excavation and grading work — Keystone LandWorks brings 25 years
          of experience to every {area.city} project.
        </p>
        <p>
          We work throughout {area.county} and the entire Northern Neck, so scheduling and
          on-site visits are straightforward. No long-distance contractor charging travel time
          from Richmond or Fredericksburg.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 style="text-align: center;">Services Available in {area.city}, {area.state}</h2>
      <p style="text-align: center; max-width: 700px; margin: 1rem auto 2.5rem;">
        Every service we offer is available to {area.city} property owners. Pick the service that
        fits your project to learn more.
      </p>

      <div class="grid grid-3">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}/`} class="card service-card">
            <h3>{s.name} in {area.city}</h3>
            <p>{s.short}</p>
            <span class="card-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="grid grid-2" style="align-items: start;">
        <div>
          <h2>Why {area.city} Property Owners Choose Keystone LandWorks</h2>
          <ul class="feature-list">
            <li><strong>Locally based</strong> — based in the Northern Neck, not a distant city. We know the region.</li>
            <li><strong>25 years in business</strong> — long-term track record across {area.county} and beyond.</li>
            <li><strong>Licensed and insured</strong> — full coverage for the work we do on your property.</li>
            <li><strong>Free on-site estimates</strong> — we walk the property before we quote.</li>
            <li><strong>Straight communication</strong> — clear quotes, no surprise add-ons.</li>
            <li><strong>5-star Google reviews</strong> — and a phone that gets answered.</li>
          </ul>
        </div>
        <div>
          <h2>Get an Estimate in {area.city}</h2>
          <p>
            The fastest way to get started is to call directly. We will set up a time to walk
            your {area.city} property, talk through the work, and give you a written estimate.
          </p>
          <p style="margin-top: 1.5rem;">
            <strong>Phone:</strong> <a href={`tel:${SITE.phoneRaw}`} class="phone-link">{SITE.phone}</a><br/>
            <strong>Email:</strong> <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </p>
          <a href="/contact" class="btn btn-primary btn-large" style="margin-top: 1rem;">Request a Free Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container" style="text-align: center;">
      <h2>Other Service Areas Nearby</h2>
      <div class="area-cloud" style="justify-content: center; margin-top: 1.5rem;">
        {SERVICE_AREAS.filter(a => a.slug !== area.slug).map(a => (
          <a href={`/service-areas/${a.slug}/`}>{a.city}, {a.state}</a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title={`Need land work in ${area.city}, ${area.state}?`}
    subtitle={`Call ${SITE.phone} or request a free estimate online. We typically schedule on-site visits within a few business days.`}
  />
</BaseLayout>

<style>
  .service-card { display: block; text-decoration: none; color: inherit; }
  .card-link { display: inline-block; margin-top: 1rem; color: var(--color-accent-dark); font-weight: 600; }
</style>
