---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { SITE, SERVICES } from '../../consts.js';

const title = 'Land Services in the Northern Neck of Virginia';
const description = 'Forestry mulching, land clearing, excavation, gravel driveway installation, and homesite preparation across the Northern Neck of Virginia. Free estimates from Keystone LandWorks.';
---

<BaseLayout title={title} description={description}>
  <section>
    <div class="container container-narrow" style="text-align: center;">
      <p class="eyebrow">Our Services</p>
      <h1>Professional Land Services in the Northern Neck of Virginia</h1>
      <p style="font-size: 1.15rem; margin-top: 1rem;">
        Keystone LandWorks offers a full range of land services for property owners,
        homebuilders, and landowners across Essex, Richmond, Lancaster, Northumberland,
        and Westmoreland Counties.
      </p>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="grid grid-2">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}/`} class="card service-card">
            <h2 style="font-size: 1.4rem;">{s.name}</h2>
            <p>{s.description}</p>
            <span class="card-link">Read more about {s.name.toLowerCase()} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
  .service-card { display: block; text-decoration: none; color: inherit; }
  .card-link { display: inline-block; margin-top: 1rem; color: var(--color-accent-dark); font-weight: 600; }
</style>
