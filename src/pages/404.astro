---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts.js';
---

<BaseLayout title="Page Not Found" description="The page you are looking for does not exist." noindex={true}>
  <section style="padding: 6rem 0;">
    <div class="container container-narrow" style="text-align: center;">
      <p class="eyebrow">404</p>
      <h1>Page Not Found</h1>
      <p style="font-size: 1.15rem; margin-top: 1rem;">
        The page you are looking for does not exist or has moved.
      </p>
      <div style="margin-top: 2rem;">
        <a href="/" class="btn btn-primary btn-large">Back to Home</a>
        <a href={`tel:${SITE.phoneRaw}`} class="btn btn-secondary btn-large" style="margin-left: 0.5rem;">Call {SITE.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
