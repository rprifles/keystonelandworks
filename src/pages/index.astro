---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { SITE, SERVICES, SERVICE_AREAS, BLOG_POSTS } from '../consts.js';

const title = 'Forestry Mulching, Land Clearing & Excavation in the Northern Neck, VA';
const description = 'Keystone LandWorks LLC offers forestry mulching, land clearing, excavation, and gravel driveway installation across the Northern Neck of Virginia. 25 years in business. Licensed and insured. Free estimates — call (804) 250-1709.';
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow hero-eyebrow">{SITE.yearsInBusiness} Years in Business · Northern Neck, Virginia</p>
      <h1>Forestry Mulching, Land Clearing &amp; Excavation Built for Real Property Work.</h1>
      <p class="hero-sub">
        Keystone LandWorks helps property owners across the Northern Neck of Virginia
        and surrounding areas clear overgrowth, open homesites, install gravel driveways,
        and prep land for what comes next. Residential and commercial work. Honest
        communication. Clean results. Professional equipment.
      </p>
      <div class="hero-ctas">
        <a href={`tel:${SITE.phoneRaw}`} class="btn btn-primary btn-large">Call {SITE.phone}</a>
        <a href="/contact" class="btn btn-secondary btn-large" style="color: white; border-color: rgba(255,255,255,0.6);">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="trust-bar">
    <div class="container">
      <div class="trust-bar-items">
        <span><strong>25</strong> Years in Business</span>
        <span><strong>★ 5.0</strong> Google Rating</span>
        <span><strong>✓</strong> Licensed &amp; Insured</span>
        <span><strong>✓</strong> Free Estimates</span>
        <span><strong>✓</strong> Locally Owned</span>
      </div>
    </div>
  </div>

  <!-- Services overview -->
  <section>
    <div class="container">
      <div style="text-align: center; max-width: 700px; margin: 0 auto 3rem;">
        <p class="eyebrow">What We Do</p>
        <h2>Professional Land Services Across the Northern Neck</h2>
        <p>
          From overgrown lots and rough timberland to homesites, driveways, and pasture cleanup —
          Keystone LandWorks handles the work that turns difficult property into usable land.
          Residential and commercial projects across the Northern Neck and surrounding areas.
        </p>
      </div>

      <div class="grid grid-3">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}/`} class="card service-card">
            <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12l2-2 4 4 8-8 4 4"/>
              <path d="M3 20h18"/>
            </svg>
            <h3>{s.name}</h3>
            <p>{s.short}</p>
            <span class="card-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service areas -->
  <section class="section-alt">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start;">
        <div>
          <p class="eyebrow">Where We Work</p>
          <h2>Serving the Northern Neck and Surrounding Areas</h2>
          <p style="max-width: 700px;">
            Keystone LandWorks serves homeowners, farmers, hunters, and developers across
            Essex, Richmond, Lancaster, Northumberland, Westmoreland, Middlesex, Gloucester, and King William Counties. If your
            property is in the Northern Neck — or just across the river in Middlesex or King George —
            we likely cover it.
          </p>
          <div class="area-cloud" style="margin-top: 1.5rem;">
            {SERVICE_AREAS.map(a => (
              <a href={`/service-areas/${a.slug}/`}>{a.city}, {a.state}</a>
            ))}
          </div>
          <p style="margin-top: 1.5rem;">
            <a href="/service-areas" class="btn btn-secondary">See All Service Areas</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section>
    <div class="container">
      <div style="text-align: center; max-width: 700px; margin: 0 auto 3rem;">
        <p class="eyebrow">Why Property Owners Call Us</p>
        <h2>25 Years of Doing the Work the Right Way</h2>
      </div>

      <div class="grid grid-3">
        <div>
          <h3>Real Experience</h3>
          <p>
            A quarter century of land clearing, forestry mulching, and excavation work
            across the Northern Neck. We have seen the terrain, the soils, and the
            seasonal challenges. Every job benefits from that knowledge.
          </p>
        </div>
        <div>
          <h3>Honest Communication</h3>
          <p>
            We walk the property, talk through the work, and give you a straight quote.
            No vague pricing. No bait-and-switch. You will know what we are doing and
            why before we start a single machine.
          </p>
        </div>
        <div>
          <h3>Clean Finished Work</h3>
          <p>
            The job is not done when the machine shuts off. It is done when the property
            looks like something you are proud of. That is the only standard worth
            working to, and it is the only standard we have.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured project photos -->
  <section>
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: end; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <p class="eyebrow">Recent Work</p>
          <h2>Real Projects, Real Results</h2>
        </div>
        <a href="/gallery" class="btn btn-secondary">View Full Gallery</a>
      </div>

      <div class="photo-grid">
        <figure>
          <img src="/images/long-gravel-driveway-installation-virginia.jpg" alt="Long gravel driveway installation through wooded property in the Northern Neck of Virginia" loading="lazy" />
          <figcaption>Gravel Driveway Install</figcaption>
        </figure>
        <figure>
          <img src="/images/forestry-mulching-pine-trees-northern-neck.jpg" alt="Forestry mulching with mature pine trees preserved on a Northern Neck Virginia property" loading="lazy" />
          <figcaption>Selective Forestry Mulching</figcaption>
        </figure>
        <figure>
          <img src="/images/waterfront-lot-clearing-finished-northern-neck.jpg" alt="Forestry mulched access road through a Northern Neck Virginia property" loading="lazy" />
          <figcaption>Forestry Mulched Access Road</figcaption>
        </figure>
        <figure>
          <img src="/images/case-excavator-skid-steer-land-clearing-virginia.jpg" alt="Case excavator and skid steer on a land clearing project in Virginia" loading="lazy" />
          <figcaption>Land Clearing in Action</figcaption>
        </figure>
        <figure>
          <img src="/images/gravel-driveway-crowned-virginia.jpg" alt="New gravel driveway with proper crown for water drainage" loading="lazy" />
          <figcaption>Driveway Done Right</figcaption>
        </figure>
        <figure>
          <img src="/images/garage-pad-site-prep-virginia.jpg" alt="Finished gravel driveway with grading around a new garage in Virginia" loading="lazy" />
          <figcaption>Site Prep and Driveway</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Blog teaser -->
  <section class="section-alt">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: end; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <p class="eyebrow">Land Owner Resources</p>
          <h2>Helpful Reading Before You Hire a Land Contractor</h2>
        </div>
        <a href="/blog" class="btn btn-secondary">View All Articles</a>
      </div>

      <div class="grid grid-3">
        {BLOG_POSTS.slice(0, 3).map(post => (
          <a href={`/blog/${post.slug}/`} class="card">
            <h3>{post.title}</h3>
            <p>{post.description}</p>
            <span class="card-link">Read article →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />

</BaseLayout>

<style>
  .service-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .card-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-accent-dark);
    font-weight: 600;
    font-size: 0.95rem;
  }
</style>
